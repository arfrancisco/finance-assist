# URL of the finance-assist Rails app
# Use http://localhost:3000 for local development
# Use your Railway/Render URL for production
FINANCE_ASSIST_URL=http://localhost:3000

# Must match MCP_API_KEY set on the Rails server
# Generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(32)"
MCP_API_KEY=your_mcp_api_key_here
