# Database
DATABASE_URL=postgresql://localhost/finance_assist_development

# EODHD Market Data API (https://eodhd.com)
# Free tier: ~20 API calls per day
EODHD_API_KEY=your_eodhd_api_key_here

# LLM Provider for report generation
# Options: anthropic, openai
LLM_PROVIDER=anthropic

# Anthropic (Claude)
# Default model: claude-opus-4-6
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (alternative LLM provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# PSE EDGE disclosure collector
# Identifies the bot in HTTP requests; keep this polite and identifiable
PSE_EDGE_USER_AGENT=finance-assist-personal/1.0 (personal research tool)

# Raw data storage directory (absolute path or relative to Rails root)
# Raw API responses and HTML pages are stored here for auditability
RAW_DATA_DIR=data/raw

# Puma thread count (default: 5)
RAILS_MAX_THREADS=5

# GraphQL API / MCP authentication key
# Required on Rails server (Railway Variables tab) and in mcp-server/.env
# Generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(32)"
MCP_API_KEY=your_mcp_api_key_here
