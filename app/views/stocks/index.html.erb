<h1 class="text-xl font-semibold mb-6">Stocks (<%= @stocks.size %>)</h1>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Symbol</th>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Company</th>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Sector</th>
        <th class="px-4 py-3 text-right font-medium text-gray-500">Latest Price Date</th>
        <th class="px-4 py-3 text-right font-medium text-gray-500">Close</th>
        <th class="px-4 py-3 text-right font-medium text-gray-500">Price Rows</th>
        <th class="px-4 py-3 text-right font-medium text-gray-500">Disclosures</th>
        <th class="px-4 py-3 text-right font-medium text-gray-500">Predictions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @stocks.empty? %>
        <tr>
          <td colspan="8" class="px-4 py-6 text-center text-gray-400">No stocks ingested yet.</td>
        </tr>
      <% else %>
        <%# latest_price_date, latest_close, price_count, disclosure_count, prediction_count
            are virtual attributes computed in the controller via correlated subqueries. %>
        <% @stocks.each do |stock| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium">
              <%= link_to stock.symbol, stock_path(stock), class: "text-blue-600 hover:underline" %>
            </td>
            <td class="px-4 py-3 text-gray-700"><%= stock.company_name %></td>
            <td class="px-4 py-3 text-gray-500"><%= stock.sector %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= stock.latest_price_date %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= stock.latest_close ? number_with_precision(stock.latest_close.to_f, precision: 2) : "—" %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= number_with_delimiter(stock.price_count) %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= stock.disclosure_count %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= stock.prediction_count %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
