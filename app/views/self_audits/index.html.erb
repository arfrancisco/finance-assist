<%# Model accuracy audit dashboard.
    Populated by `bin/rails finance:self_audit` (run weekly).
    Shows hit rate, average return, excess return vs PSEi benchmark, and Brier score per horizon. %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-semibold">Model Audit</h1>
    <p class="text-sm text-gray-500 mt-0.5">Prediction accuracy over time by horizon</p>
  </div>
  <code class="text-xs text-gray-400 bg-gray-100 px-3 py-1.5 rounded">bin/rails finance:self_audit</code>
</div>

<% if @audit_runs.empty? %>
  <div class="bg-white rounded-lg border border-gray-200 px-6 py-16 text-center">
    <p class="text-gray-400 text-sm mb-2">No audit runs yet.</p>
    <p class="text-gray-300 text-xs">
      Run <code class="bg-gray-100 px-1 rounded">bin/rails finance:self_audit</code> to generate the first report.
      Requires at least one prediction horizon to have elapsed so outcomes can be evaluated.
    </p>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Run Date</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Horizon</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Sample Size</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Hit Rate</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Avg Return</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Avg Excess Return</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Brier Score</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Notes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @audit_runs.each do |run| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 whitespace-nowrap"><%= run.run_date.strftime("%b %d, %Y") %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs font-medium"><%= run.horizon %></span>
            </td>
            <td class="px-4 py-3 text-right text-gray-600"><%= number_with_delimiter(run.sample_size) %></td>
            <td class="px-4 py-3 text-right font-medium <%= run.hit_rate >= 0.5 ? 'text-green-600' : 'text-red-500' %>">
              <%= run.hit_rate ? number_to_percentage(run.hit_rate * 100, precision: 1) : "—" %>
            </td>
            <td class="px-4 py-3 text-right <%= run.avg_return&.positive? ? 'text-green-600' : 'text-red-500' %>">
              <%= run.avg_return ? number_to_percentage(run.avg_return * 100, precision: 2) : "—" %>
            </td>
            <td class="px-4 py-3 text-right <%= run.avg_excess_return&.positive? ? 'text-green-600' : 'text-red-500' %>">
              <%= run.avg_excess_return ? number_to_percentage(run.avg_excess_return * 100, precision: 2) : "—" %>
            </td>
            <td class="px-4 py-3 text-right text-gray-600 font-mono text-xs">
              <%# Brier score: lower is better (0 = perfect, 0.25 = uninformative baseline) %>
              <%= run.brier_score ? number_with_precision(run.brier_score, precision: 4) : "—" %>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs max-w-xs truncate" title="<%= run.calibration_notes %>">
              <%= run.calibration_notes.presence || "—" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <p class="mt-3 text-xs text-gray-400">
    Hit rate &gt; 50% indicates above-random directional accuracy.
    Brier score &lt; 0.25 indicates better-than-baseline probability calibration.
    Excess return is vs. PSEi benchmark over the same horizon.
  </p>
<% end %>
