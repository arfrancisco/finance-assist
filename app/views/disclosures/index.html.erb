<h1 class="text-xl font-semibold mb-6">Disclosures</h1>

<%= form_with url: disclosures_path, method: :get, class: "flex flex-wrap gap-3 mb-6" do |f| %>
  <%= f.text_field :symbol, value: params[:symbol], placeholder: "Symbol (e.g. ALI)", class: "border border-gray-300 rounded px-3 py-1.5 text-sm w-32" %>
  <%= f.submit "Filter", class: "bg-blue-600 text-white rounded px-4 py-1.5 text-sm hover:bg-blue-700 cursor-pointer" %>
  <% if params[:symbol].present? %>
    <%= link_to "Clear", disclosures_path, class: "text-sm text-gray-500 hover:underline self-center" %>
  <% end %>
<% end %>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Date</th>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Symbol</th>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Type</th>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Title</th>
        <th class="px-4 py-3 text-left font-medium text-gray-500">Fetched At</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @disclosures.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-6 text-center text-gray-400">No disclosures yet.</td>
        </tr>
      <% else %>
        <% @disclosures.each do |d| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2 whitespace-nowrap"><%= d.disclosure_date %></td>
            <td class="px-4 py-2 font-medium">
              <%= link_to d.stock.symbol, stock_path(d.stock), class: "text-blue-600 hover:underline" %>
            </td>
            <td class="px-4 py-2 text-gray-500 whitespace-nowrap"><%= d.disclosure_type %></td>
            <td class="px-4 py-2">
              <% if d.source_url.present? %>
                <%= link_to d.title, d.source_url, target: "_blank", class: "text-blue-600 hover:underline" %>
              <% else %>
                <%= d.title %>
              <% end %>
            </td>
            <td class="px-4 py-2 text-gray-400 whitespace-nowrap"><%= d.fetched_at ? l(d.fetched_at, format: :short) : "—" %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
<% if @disclosures.size == 200 %>
  <p class="mt-3 text-sm text-gray-400">Showing first 200 results. Use the symbol filter to narrow down.</p>
<% end %>
