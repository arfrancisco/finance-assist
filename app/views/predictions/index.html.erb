<%# Predictions page — shows top 10 by default; toggle to view all.
    Params: ?horizon=20d  (default 20d)
            ?date=YYYY-MM-DD (default latest)
            ?show=all   (removes top-10 limit)
            ?symbol=ALI (filters by stock symbol, case-insensitive) %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold">
    Predictions
    <span class="ml-2 text-sm font-normal text-gray-400">(<%= @total_count %>)</span>
  </h1>

  <%# Date selector + symbol filter — both preserve the current horizon and show mode %>
  <%= form_with url: predictions_path, method: :get do |f| %>
    <div class="flex items-center gap-2">
      <%= f.hidden_field :horizon, value: @horizon %>
      <%= f.hidden_field :show,    value: (@show_all ? "all" : nil) if @show_all %>
      <%= f.text_field :symbol,
            value: @symbol,
            placeholder: "Symbol…",
            class: "text-sm border border-gray-300 rounded px-2 py-1 w-24 bg-white" %>
      <%= f.select :date,
            @dates.map { |d| [d.strftime("%b %d, %Y"), d.iso8601] },
            { selected: @date.iso8601 },
            class: "text-sm border border-gray-300 rounded px-2 py-1 bg-white" %>
      <%= f.submit "Go", class: "text-sm px-3 py-1 bg-gray-100 border border-gray-300 rounded hover:bg-gray-200 cursor-pointer" %>
      <% if @symbol.present? %>
        <%= link_to "Clear",
              predictions_path(horizon: @horizon, date: @date.iso8601, show: (@show_all ? "all" : nil)),
              class: "text-sm text-gray-400 hover:text-gray-600" %>
      <% end %>
    </div>
  <% end %>
</div>

<%# Horizon tab switcher — preserves show mode and symbol when switching horizons %>
<div class="flex gap-1 mb-4 border-b border-gray-200">
  <% PredictionsController::HORIZONS.each do |h| %>
    <%= link_to predictions_path(horizon: h, date: @date.iso8601, show: (@show_all ? "all" : nil), symbol: @symbol),
          class: "px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors #{h == @horizon ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'}" do %>
      <%= h == "5d" ? "5-Day" : h == "20d" ? "20-Day" : "60-Day" %>
    <% end %>
  <% end %>
</div>

<%# Top-10 / All toggle %>
<div class="flex items-center justify-between mb-4 text-sm">
  <% if @show_all %>
    <span class="text-gray-500">
      Showing all <%= @symbol.present? ? "matching" : @total_count.to_s %> predictions
      <% unless @symbol.present? %>
        — <%= link_to "Back to top 10 ←",
              predictions_path(horizon: @horizon, date: @date.iso8601, symbol: @symbol),
              class: "text-blue-600 hover:underline" %>
      <% end %>
    </span>
  <% else %>
    <span class="text-gray-500">
      Showing top <%= PredictionsController::DEFAULT_LIMIT %>
      — <%= link_to "View all #{@total_count} →",
            predictions_path(horizon: @horizon, date: @date.iso8601, show: "all", symbol: @symbol),
            class: "text-blue-600 hover:underline" %>
    </span>
  <% end %>
  <span class="text-gray-400">As of <%= @date.strftime("%b %d, %Y") %></span>
</div>

<% if @predictions.empty? %>
  <div class="bg-white rounded-lg border border-gray-200 px-6 py-12 text-center text-gray-400">
    <% if @symbol.present? %>
      No predictions found for "<%= @symbol %>" on the <%= @horizon %> horizon on <%= @date.strftime("%b %d, %Y") %>.
    <% else %>
      No predictions found for <%= @horizon %> horizon on <%= @date.strftime("%b %d, %Y") %>.
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-medium text-gray-500 w-10">#</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Symbol</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Company</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Score</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Probability</th>
          <th class="px-4 py-3 text-center font-medium text-gray-500">Direction</th>
          <th class="px-4 py-3 text-right font-medium text-gray-500">Exp. Return</th>
          <th class="px-4 py-3 text-center font-medium text-gray-500">Signal</th>
          <th class="px-4 py-3 text-center font-medium text-gray-500">Report</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @predictions.each do |p| %>
          <%# Each prediction may have an expandable AI report panel below it %>
          <tr class="hover:bg-gray-50 cursor-pointer"
              onclick="this.nextElementSibling.classList.toggle('hidden')">
            <td class="px-4 py-3 text-gray-400 font-mono"><%= p.rank_position %></td>
            <td class="px-4 py-3 font-medium">
              <%= link_to p.stock.symbol, stock_path(p.stock),
                    class: "text-blue-600 hover:underline",
                    onclick: "event.stopPropagation()" %>
            </td>
            <td class="px-4 py-3 text-gray-700"><%= p.stock.company_name %></td>
            <td class="px-4 py-3 text-right font-mono text-gray-800"><%= number_with_precision(p.total_score, precision: 4) %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= number_to_percentage(p.predicted_probability * 100, precision: 1) %></td>
            <td class="px-4 py-3 text-center">
              <% if p.predicted_direction == "up" %>
                <span class="text-green-600 font-medium">▲ Up</span>
              <% elsif p.predicted_direction == "down" %>
                <span class="text-red-500 font-medium">▼ Down</span>
              <% else %>
                <span class="text-gray-400">— Flat</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right text-gray-600 font-mono text-xs">
              <% if p.expected_return_min && p.expected_return_max %>
                <%= number_to_percentage(p.expected_return_min * 100, precision: 1) %> /
                +<%= number_to_percentage(p.expected_return_max * 100, precision: 1) %>
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-4 py-3 text-center">
              <% badge_class = case p.recommendation_type
                               when "buy"       then "bg-green-100 text-green-700"
                               when "sell"      then "bg-red-100 text-red-600"
                               when "watchlist" then "bg-yellow-100 text-yellow-700"
                               else                  "bg-gray-100 text-gray-500"
                               end %>
              <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= badge_class %>">
                <%= p.recommendation_type&.capitalize || "—" %>
              </span>
            </td>
            <td class="px-4 py-3 text-center">
              <% if p.prediction_report %>
                <span class="text-blue-400" title="AI report available">📄</span>
              <% else %>
                <span class="text-gray-300">—</span>
              <% end %>
            </td>
          </tr>

          <%# Expandable AI report panel — hidden by default, toggled by row click %>
          <tr class="hidden bg-blue-50">
            <td colspan="9" class="px-6 py-5">
              <% if p.prediction_report %>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                  <% if p.prediction_report.summary_text.present? %>
                    <div class="md:col-span-2">
                      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Summary</p>
                      <p class="text-gray-700"><%= p.prediction_report.summary_text %></p>
                    </div>
                  <% end %>
                  <% if p.prediction_report.catalyst_text.present? %>
                    <div>
                      <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Catalyst</p>
                      <p class="text-gray-700"><%= p.prediction_report.catalyst_text %></p>
                    </div>
                  <% end %>
                  <% if p.prediction_report.risk_text.present? %>
                    <div>
                      <p class="text-xs font-semibold text-red-500 uppercase tracking-wide mb-1">Risk</p>
                      <p class="text-gray-700"><%= p.prediction_report.risk_text %></p>
                    </div>
                  <% end %>
                  <% if p.prediction_report.guidance_text.present? %>
                    <div class="md:col-span-2 bg-white rounded border border-blue-200 px-3 py-2">
                      <p class="text-xs font-semibold text-blue-700 uppercase tracking-wide mb-1">The Model's View</p>
                      <p class="text-gray-700"><%= p.prediction_report.guidance_text %></p>
                    </div>
                  <% end %>
                  <% if p.prediction_report.rationale_text.present? %>
                    <div class="md:col-span-2">
                      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Rationale</p>
                      <p class="text-gray-600 text-xs"><%= p.prediction_report.rationale_text %></p>
                    </div>
                  <% end %>
                  <% if p.prediction_report.education_text.present? %>
                    <div class="md:col-span-2">
                      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">For Beginners</p>
                      <p class="text-gray-600 text-xs italic"><%= p.prediction_report.education_text %></p>
                    </div>
                  <% end %>
                  <div class="md:col-span-2 text-xs text-gray-400 pt-1 border-t border-blue-100">
                    Model: <%= p.prediction_report.llm_model %> · Prompt v<%= p.prediction_report.prompt_version %>
                  </div>
                </div>
              <% else %>
                <p class="text-sm text-gray-400 italic">No AI report generated for this prediction yet.</p>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <p class="mt-3 text-xs text-gray-400">Click any row to expand the AI-generated report.</p>
<% end %>
